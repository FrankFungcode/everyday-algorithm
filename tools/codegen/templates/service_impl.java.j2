{% if 'create' in operations %}

    @Override
    @Transactional
    public {{ name }}IdVo create({{ name }}CreateParam param) {
{% for f in unique_fields %}
        assert{{ f.capName }}Available(param.get{{ f.capName }}(), null);
{% endfor %}
        {{ entity }} entity = new {{ entity }}();
{% for f in fields %}
        entity.set{{ f.capName }}(param.get{{ f.capName }}());
