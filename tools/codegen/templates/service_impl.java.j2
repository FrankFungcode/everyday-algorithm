{% if 'update' in operations %}

    @Override
    @Transactional
    public void update(UUID id, {{ name }}UpdateParam param) {
        {{ entity }} entity = {{ repo_var }}.findByIdOrThrow(id);
{% for f in unique_fields %}
        if (param.get{{ f.capName }}() != null) {
            assert{{ f.capName }}Available(param.get{{ f.capName }}(), id);
        }
{% endfor %}
{% for f in fields %}
        if (param.get{{ f.capName }}() != null) {
            entity.set{{ f.capName }}(param.get{{ f.capName }}());
        }
{% endfor %}
        {{ repo_var }}.save(entity);
    }
{% endif %}
{% if 'getById' in operations %}

    @Override
    @Transactional(readOnly = true)
    public {{ name }}Vo getById(UUID id) {
        return toVo({{ repo_var }}.findByIdOrThrow(id));
    }
